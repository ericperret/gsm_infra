n/bash</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(110, 118, 135);"># recuperation-osmo-epdg.sh | 2026-05-27 | v1.0</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(110, 118, 135);"># Clone osmo-epdg dans ~/Downloads/Erlang</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(0, 81, 194);">mkdir</span><span> -p ~/Downloads/Erlang
</span></span><span><span></span><span class="token token" style="color: rgb(179, 74, 0);">cd</span><span> ~/Downloads/Erlang
</span></span><span><span></span><span class="token token" style="color: rgb(0, 81, 194);">git</span><span> clone https://gitea.osmocom.org/ims-volte-vowifi/osmo-epdg
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(179, 74, 0);">echo</span><span> </span><span class="token token" style="color: rgb(0, 128, 0);">"--- Structure ---"</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(0, 81, 194);">find</span><span> osmo-epdg -type f </span><span class="token token" style="color: rgb(20, 24, 31);">|</span><span> </span><span class="token token" style="color: rgb(0, 81, 194);">sort</span></span></code></pre></div></div>
