### **Verification — 7 fichiers**

| for f in osmo-stp osmo-hlr osmo-mgw osmo-msc osmo-sgsn osmo-bsc osmo-cbc; do |
| --- |
| echo -n "$f.cfg : " |
| wc -l /etc/osmocom/$f.cfg │ awk '{print $1, "lignes"}' |
| done |

## **Etape 4/6 — Services systemd Osmocom : enable + start**

| sudo systemctl enable osmo-stp  && sudo systemctl start osmo-stp |
| --- |
| systemctl is-active osmo-stp  && echo 'OK' ││ echo 'FAIL' |
|  |
| sudo systemctl enable osmo-hlr  && sudo systemctl start osmo-hlr |
| systemctl is-active osmo-hlr  && echo 'OK' ││ echo 'FAIL' |
|  |
| sudo systemctl enable osmo-mgw  && sudo systemctl start osmo-mgw |
| systemctl is-active osmo-mgw  && echo 'OK' ││ echo 'FAIL' |
|  |
| sudo systemctl enable osmo-msc  && sudo systemctl start osmo-msc |
| systemctl is-active osmo-msc  && echo 'OK' ││ echo 'FAIL' |
|  |
| sudo systemctl enable osmo-sgsn && sudo systemctl start osmo-sgsn |
| systemctl is-active osmo-sgsn && echo 'OK' ││ echo 'FAIL' |
|  |
| sudo systemctl enable osmo-bsc  && sudo systemctl start osmo-bsc |
| systemctl is-active osmo-bsc  && echo 'OK' ││ echo 'FAIL' |
|  |
| sudo systemctl enable osmo-cbc  && sudo systemctl start osmo-cbc |
| systemctl is-active osmo-cbc  && echo 'OK' ││ echo 'FAIL' |

### **Verification globale**

| for svc in osmo-stp osmo-hlr osmo-mgw osmo-msc osmo-sgsn osmo-bsc osmo-cbc; do |
| --- |
| state=$(systemctl is-active $svc) |
| enabled=$(systemctl is-enabled $svc) |
| printf '%-12s  actif=%-10s  enabled=%s\n' "$svc" "$state" "$enabled" |
| done |

### **Diagnostic si un service est en failed**

| sudo journalctl -u osmo-NOM.service -n 30 --no-pager |
| --- |

## **Etape 5/6 — OsmoBSC : sysmoBTS 2100, Abis-over-IP, 3 secteurs 120 degres**

### **Bloc 1 — Sauvegarde**

| sudo cp /etc/osmocom/osmo-bsc.cfg /etc/osmocom/osmo-bsc.cfg.bak |
| --- |

### **Bloc 2 — Config complete 3 secteurs**

| sudo tee /etc/osmocom/osmo-bsc.cfg > /dev/null << 'EOF' |
| --- |
| ! OsmoBSC sysmoBTS 2100 - Abis-over-IP - 3 secteurs 120 degres |
| ! MCC=547  MNC=PLACEHOLDER |
| line vty |
| no login |
| bind 127.0.0.1 |
| network |
| network country code 547 |
| mobile network code PLACEHOLDER |
| short name OsmoNet |
| long name OsmoNet |
| auth policy closed |
| encryption a5 0 |
| neci 1 |
| mm info 1 |
| cs7 instance 0 |
| point-code 0.23.2 |
| asp asp-clnt-bsc 2905 0 m3ua |
| remote-ip 10.0.0.1 |
| role asp |
| sctp-role client |
| as as-clnt-bsc m3ua |
| asp asp-clnt-bsc |
| routing-key 1 0.23.2 |
| msc 0 |
| msc-addr 10.0.0.1 |
| codec-list fr1 |
| ! --- BTS 0 Secteur 1 Az0 --- |
| bts 0 |
| type sysmobts |
| band PLACEHOLDER_BAND |
| description Secteur-1-Az0 |
| location_area_code 1 / cell_identity 1 |
| base_station_id_code 0 |
| oml remote-ip 10.0.0.1 |
| gprs mode gprs / gprs cell bvci 2 |
| gprs nsvc 0 remote ip 10.0.0.1 |
| gprs nsvc 0 remote udp port 23000 |
| gprs nsvc 0 local udp port 23000 |
| gprs nsvc 0 nsvci 1 |
| trx 0 |
| arfcn PLACEHOLDER_ARFCN_S1 |
| nominal power PLACEHOLDER_PWR_DBM |
| timeslot 0 : CCCH+SDCCH4 |
| timeslot 1 : SDCCH8 |
| timeslots 2-7 : TCH/F |
| ! --- BTS 1 Secteur 2 Az120 --- (meme structure bvci=3 nsvc=23001 nsvci=2) |
| ! --- BTS 2 Secteur 3 Az240 --- (meme structure bvci=4 nsvc=23002 nsvci=3) |
| EOF |

### **Bloc 3 — Redemarrage + verification**

| sudo systemctl restart osmo-bsc |
| --- |
| sleep 2 |
| systemctl is-active osmo-bsc && echo 'OK' ││ echo 'FAIL' |

### **PLACEHOLDERs BSC**

| **Placeholder** | **Valeur a fournir** |
| --- | --- |
| PLACEHOLDER_BAND | ex: DCS1800 ou GSM900 |
| PLACEHOLDER_ARFCN_S1 | ARFCN secteur 1 (autorite) |
| PLACEHOLDER_ARFCN_S2 | ARFCN secteur 2 (autorite) |
| PLACEHOLDER_ARFCN_S3 | ARFCN secteur 3 (autorite) |
| PLACEHOLDER_PWR_DBM | Puissance TRX en dBm ex: 23 |
| PLACEHOLDER (MNC) | Mobile Network Code ex: 10 |

## **Etape 6/6 — Verification communications + readiness sysmoBTS**

### **Etat global + ports**

| for svc in osmo-stp osmo-hlr osmo-mgw osmo-msc osmo-sgsn osmo-bsc osmo-cbc; do |
| --- |
| printf '%-12s  %s\n' "$svc" "$(systemctl is-active $svc)" |
| done |
|  |
| sudo ss -tlnpu │ grep -E 'osmo│4222│2905│2427│4264│3003│23000' \ |
| │ awk '{print $1, $5, $7}' │ column -t |

### **VTY actif sur chaque composant**

| for port in 4239 4258 2427 4254 4245 4242 4264; do |
| --- |
| result=$(echo '' │ nc -w1 127.0.0.1 $port 2>/dev/null │ head -1) |
| [ -n "$result" ] && echo "OK $port" ││ echo "FAIL $port" |
| done |

### **Firewall port Abis 3003**

| sudo ufw allow 3003/tcp comment 'Abis-over-IP sysmoBTS' |
| --- |
| sudo ufw allow 3003/udp comment 'Abis-over-IP sysmoBTS' |
| sudo ufw status │ grep 3003 |

### **Readiness check final Osmocom**

| echo '===== OSMOCOM READINESS CHECK =====' |
| --- |
| ok=0 |
| for svc in osmo-stp osmo-hlr osmo-mgw osmo-msc osmo-sgsn osmo-bsc osmo-cbc; do |
| [ "$(systemctl is-active $svc)" = 'active' ] && ok=$((ok+1)) |
| done |
| echo "Services actifs : $ok/7" |
| sudo ss -tlnp │ grep -q 3003 && echo 'Port 3003 : OUVERT' ││ echo 'Port 3003 : FERME' |
| sudo ss -tlnp │ grep -q 4222 && echo 'Port 4222 : OUVERT' ││ echo 'Port 4222 : FERME' |
| sudo ss -tlnp │ grep -q 2905 && echo 'Port 2905 : OUVERT' ││ echo 'Port 2905 : FERME' |
| count=$(grep -c 'description Secteur' /etc/osmocom/osmo-bsc.cfg) |
| echo "Secteurs declares : $count/3" |
| echo '===================================' |

### **Surveillance connexion BTS en temps reel**

| sudo journalctl -u osmo-bsc -f │ grep -E 'OML│BTS│TRX│RSL│connect' |
| --- |

# **PARTIE 2 — OPEN5GS 4G LTE**

## **Etape 1/5 — Depot Open5GS + installation 16 composants**

### **Cle GPG + depot**

| sudo apt install -y gnupg curl wget ca-certificates apt-transport-https |
| --- |
|  |
| curl -fsSL https://download.opensuse.org/repositories/home:/acetcom/xUbuntu_24.04/Release.key \ |
| │ gpg --dearmor \ |
| │ sudo tee /usr/share/keyrings/open5gs.gpg > /dev/null |
|  |
| echo "deb [signed-by=/usr/share/keyrings/open5gs.gpg] \ |
| https://download.opensuse.org/repositories/home:/acetcom/xUbuntu_24.04/ ./" \ |
| │ sudo tee /etc/apt/sources.list.d/open5gs.list |
|  |
| sudo apt update 2>&1 │ grep -E "open5gs│acetcom│Err" |

### **Installation 16 composants**

| sudo apt install -y \ |
| --- |
| open5gs-mme  open5gs-sgwc open5gs-sgwu \ |
| open5gs-smf  open5gs-upf  open5gs-hss  \ |
| open5gs-pcrf open5gs-nrf  open5gs-scp  \ |
| open5gs-ausf open5gs-udm  open5gs-udr  \ |
| open5gs-pcf  open5gs-nssf open5gs-bsf  \ |
| open5gs-amf |

### **Verification — 16 paquets**

| dpkg -l open5gs-mme open5gs-sgwc open5gs-sgwu open5gs-smf open5gs-upf \ |
| --- |
| open5gs-hss open5gs-pcrf open5gs-nrf open5gs-scp open5gs-ausf \ |
| open5gs-udm open5gs-udr open5gs-pcf open5gs-nssf open5gs-bsf open5gs-amf \ |
| │ awk '/^[ih]i/{print $2, $3}' │ column -t |

## **Etape 2/5 — Configuration MME, SGW, PGW, HSS, PCRF**

### **Sauvegarde**

| sudo mkdir -p /etc/open5gs/backup |
| --- |
| sudo cp /etc/open5gs/*.yaml /etc/open5gs/backup/ |

### **mme.yaml**

| sudo tee /etc/open5gs/mme.yaml > /dev/null << 'EOF' |
| --- |
| # Open5GS MME  MCC=547  MNC=PLACEHOLDER  IP=PLACEHOLDER_IP |
| logger: |
| file: { path: /var/log/open5gs/mme.log } |
| level: info |
| mme: |
| s1ap: |
| server: [ { address: PLACEHOLDER_IP } ] |
| gtpc: |
| server: [ { address: PLACEHOLDER_IP } ] |
| client: |
| sgwc: [ { address: PLACEHOLDER_IP } ] |
| gummei: |
| - plmn_id: { mcc: '547', mnc: 'PLACEHOLDER' } |
| mme_gid: 1 |
| mme_code: 1 |
| tai: |
| - plmn_id: { mcc: '547', mnc: 'PLACEHOLDER' } |
| tac: 1 |
| security: |
| integrity_order: [ EIA2, EIA1, EIA0 ] |
| ciphering_order: [ EEA0, EEA1, EEA2 ] |
| network_name: { full: OsmoNet, short: ONet } |
| mme_name: open5gs-mme0 |
| EOF |

